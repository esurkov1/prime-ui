{
  "name": "prime-ui-kit",
  "version": "0.7.5",
  "description": "React 19 UI kit: CSS Modules, semantic design tokens (--prime-sys-*), composable components — forms, modals, selects, tables, navigation, overlays. TypeScript, ESM, a11y-oriented.",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "keywords": [
    "a11y",
    "accessible",
    "component-library",
    "composable",
    "css-modules",
    "css-variables",
    "dark-mode",
    "data-table",
    "datepicker",
    "design-system",
    "design-tokens",
    "dialog",
    "drawer",
    "dropdown",
    "esm",
    "forms",
    "framer-motion",
    "light-mode",
    "lucide-react",
    "modal",
    "nextjs",
    "notifications",
    "npm-package",
    "popover",
    "prime-ui",
    "prime-ui-kit",
    "react",
    "react-19",
    "react-aria",
    "react-components",
    "react-day-picker",
    "react-ui",
    "reactjs",
    "remix",
    "select",
    "sidebar",
    "table",
    "theming",
    "toast",
    "tooltip",
    "typescript",
    "ui-components",
    "ui-kit",
    "vite"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/esurkov1/prime-ui.git"
  },
  "bugs": {
    "url": "https://github.com/esurkov1/prime-ui/issues"
  },
  "homepage": "https://github.com/esurkov1/prime-ui#readme",
  "files": [
    "dist",
    "src/styles/*.css",
    "src/components/**/COMPONENT.md",
    "src/layout/**/COMPONENT.md",
    "src/components/**/examples/**",
    "src/layout/**/examples/**",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "date-fns": "^4.1.0",
    "react-day-picker": "^9.14.0",
    "react-aria-components": "^1.16.0",
    "@biomejs/biome": "latest",
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "latest",
    "@testing-library/user-event": "latest",
    "@types/node": "^25.5.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5",
    "@vitest/coverage-v8": "^4.1.0",
    "jsdom": "latest",
    "esbuild": "^0.27.0",
    "typescript": "^5",
    "vite": "^7",
    "vitest": "latest"
  },
  "peerDependencies": {
    "date-fns": "^4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-aria-components": "^1.16.0",
    "react-day-picker": "^9.14.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "default": "./dist/components/index.js"
    },
    "./styles.css": "./src/styles/globals.css",
    "./tokens.css": "./src/styles/tokens.css",
    "./theme-light.css": "./src/styles/theme-light.css",
    "./theme-dark.css": "./src/styles/theme-dark.css",
    "./bundle.css": "./dist/index.css",
    "./components.css": "./dist/components/index.css"
  },
  "scripts": {
    "clean": "rm -rf dist .dts-stage coverage playground/dist",
    "tokens:build": "bun run scripts/build-tokens.ts",
    "build": "bun run tokens:build && bun run scripts/bundle-lib.ts",
    "prepublishOnly": "bun run clean && bun run build",
    "dev": "bun run scripts/bundle-lib.ts --watch",
    "playground:dev": "vite playground --config playground/vite.config.ts",
    "check": "biome check .",
    "check:ci": "biome ci .",
    "check:fix": "biome check . --write --unsafe",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "bun run check:ci && bun run typecheck && bun run test && bun run build",
    "verify:quick": "bun run check:ci && bun run typecheck && bun run test",
    "verify:tokens": "bun run tokens:build && git diff --exit-code -- src/styles/tokens.css src/styles/theme-light.css src/styles/theme-dark.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "type": "module",
  "dependencies": {
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "react-router-dom": "^7.13.1"
  }
}
